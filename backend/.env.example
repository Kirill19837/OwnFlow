SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Production frontend URL — used to build redirect_to links in invite emails.
# Must match the Supabase Redirect URL allowlist exactly.
FRONTEND_URL=https://ownflow.21century.tech
CORS_ORIGINS=https://ownflow.21century.tech

# Postmark – fill in to send invite emails directly (bypasses Supabase rate limits)
POSTMARK_TOKEN=your-postmark-server-token
POSTMARK_FROM=OwnFlow <no-reply@yourdomain.com>
